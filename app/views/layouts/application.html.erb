<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= @og_title.present? ? "#{@og_title} | 深夜薬局 Bar" : "深夜薬局 Bar" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <meta property="og:site_name" content="深夜薬局 Bar">
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= @og_title.present? ? "#{@og_title} | 深夜薬局 Bar" : "深夜薬局 Bar" %>">
    <meta property="og:description" content="<%= @og_description.present? ? @og_description : "知的好奇心に、薬を。深夜の薬剤師があなたのアイデアに服薬指導箋を発行します。" %>">
    <meta property="og:image" content="<%= "#{request.base_url}/ogp.png" %>">
    <meta property="og:url" content="<%= request.url %>">
    <meta name="twitter:card" content="summary_large_image">

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=New+Tegomin&family=Zen+Kurenaido&display=swap" rel="stylesheet">
    <%= javascript_importmap_tags %>

    <% if Rails.env.production? %>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-5BQ2FW2WN5"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-5BQ2FW2WN5');
    </script>
    <% end %>
  </head>

  <body>
    <nav class="site-nav">
      <%= link_to root_path, class: "nav-logo", title: "トップ" do %>
        <img src="/apple-touch-icon.png" class="nav-logo-img" alt="深夜薬局 Bar">
      <% end %>
      <div class="nav-links">
        <%= link_to play_path, class: "nav-icon-link", title: "服薬指導箋" do %>
          <%= inline_svg "feature1-notes.svg", css_class: "nav-icon" %>
        <% end %>
        <%= link_to new_side_effect_path, class: "nav-icon-link", title: "副作用レポート" do %>
          <%= inline_svg "feature2-diary.svg", css_class: "nav-icon" %>
        <% end %>
      </div>
    </nav>
    <% if flash[:alert] %>
      <div class="flash-alert"><%= flash[:alert] %></div>
    <% end %>
    <%= yield %>
  </body>
</html>
