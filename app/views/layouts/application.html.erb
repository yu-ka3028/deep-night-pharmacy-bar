<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= @og_title.present? ? "#{@og_title} | 深夜薬局 Bar" : "深夜薬局 Bar" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <meta property="og:site_name" content="深夜薬局 Bar">
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= @og_title.present? ? "#{@og_title} | 深夜薬局 Bar" : "深夜薬局 Bar" %>">
    <meta property="og:description" content="<%= @og_description.present? ? @og_description : "おやすみ前にフッと笑いを。深夜の柴犬薬剤師があなたのアウトプットにフィードバックを発行します。" %>">
    <meta property="og:image" content="<%= "#{request.base_url}/ogp.png" %>">
    <meta property="og:url" content="<%= request.url %>">
    <meta name="twitter:card" content="summary_large_image">

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Klee+One&family=New+Tegomin&family=Shippori+Mincho&display=swap" rel="stylesheet">
    <%= javascript_importmap_tags %>

    <% if Rails.env.production? %>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-5BQ2FW2WN5"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-5BQ2FW2WN5');
    </script>
    <% end %>
  </head>

  <body>
    <nav class="site-nav">
      <%= link_to root_path, class: "nav-logo", title: "トップ" do %>
        <img src="/apple-touch-icon.png" class="nav-logo-img" alt="深夜薬局 Bar">
      <% end %>
      <div class="nav-external">
        <%= link_to "https://forms.gle/JDaw8gmCC83MwN3t7", target: "_blank", rel: "noopener noreferrer", class: "nav-icon-link", title: "お問い合わせ" do %>
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="nav-icon" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        <% end %>
        <%= link_to "https://x.com/yuka3028", target: "_blank", rel: "noopener noreferrer", class: "nav-icon-link", title: "X (Twitter)" do %>
          <svg viewBox="0 0 24 24" class="nav-icon" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="currentColor"/>
          </svg>
        <% end %>
        <%= link_to "https://github.com/yu-ka3028/deep-night-pharmacy-bar", target: "_blank", rel: "noopener noreferrer", class: "nav-icon-link", title: "GitHub" do %>
          <svg viewBox="0 0 24 24" class="nav-icon" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" fill="currentColor"/>
          </svg>
        <% end %>
      </div>
    </nav>
    <% if flash[:alert] %>
      <div class="flash-alert"><%= flash[:alert] %></div>
    <% end %>
    <%= yield %>
    <footer class="site-footer">
      <p class="footer-name">深夜薬局 Bar</p>
      <p class="footer-copy">&copy; <%= Time.current.year %> Pharmacy-Bar</p>
    </footer>
  </body>
</html>
