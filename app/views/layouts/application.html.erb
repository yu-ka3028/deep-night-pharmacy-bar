<!DOCTYPE html>
<html>
  <head>
    <title>PharmacyBar</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="site-nav">
      <%= link_to "深夜薬局バー", root_path, class: "nav-logo" %>
      <div class="nav-links">
        <%= link_to "服薬指導箋", play_path, class: "nav-link" %>
        <%= link_to "副作用レポート", new_side_effect_path, class: "nav-link" %>
      </div>
    </nav>
    <% if flash[:alert] %>
      <div class="flash-alert"><%= flash[:alert] %></div>
    <% end %>
    <%= yield %>
  </body>
</html>
